<%
    pageTitle = 'Sign Up - StarHela';
%>
<%- include('header') %>

    <!-- Main Content -->
    <main class="site-main">
        <div class="container">
            <div class="register-container">
                <div class="register-header">
                    <h1>Join StarHela</h1>
                    <p>Start earning money through simple digital activities</p>
                </div>

                <div class="features-list">
                    <h3>How to Join StarHela:</h3>
                    <ul>
                        <li>Enter a unique username (example: samkiliswa)</li>
                        <li>Select your country</li>
                        <li>Enter your email address</li>
                        <li>Create a secure password</li>
                        <li>Complete registration and start earning</li>
                    </ul>
                </div>

                <% if (success) { %>
                    <div class="alert alert-success"><%= success %></div>
                <% } %>

                <% if (error) { %>
                    <div class="alert alert-error"><%= error %></div>
                <% } %>

                <form method="POST" action="/register">
                    <div class="form-group">
                        <label for="username">Username *</label>
                        <input type="text" id="username" name="username" required
                               placeholder="Enter unique username">
                        <small>Choose a unique username for your account</small>
                    </div>

                    <div class="form-group">
                        <label for="email">Email Address *</label>
                        <input type="email" id="email" name="email" required
                               placeholder="your@email.com">
                    </div>

                    <div class="form-group">
                        <label for="country">Country *</label>
                        <select id="country" name="country" required>
                            <option value="">Select your country</option>
                            <option value="Rwanda" <%= (typeof selectedCountry !== 'undefined' && selectedCountry === 'RW') ? 'selected' : '' %>>🇷🇼 Rwanda</option>
                            <option value="Burundi" <%= (typeof selectedCountry !== 'undefined' && selectedCountry === 'BI') ? 'selected' : '' %>>🇧🇮 Burundi</option>
                            <option value="Uganda" <%= (typeof selectedCountry !== 'undefined' && selectedCountry === 'UG') ? 'selected' : '' %>>🇺🇬 Uganda</option>
                            <option value="Ghana" <%= (typeof selectedCountry !== 'undefined' && selectedCountry === 'GH') ? 'selected' : '' %>>🇬🇭 Ghana</option>
                            <option value="Cameroon" <%= (typeof selectedCountry !== 'undefined' && selectedCountry === 'CM') ? 'selected' : '' %>>🇨🇲 Cameroon</option>
                            <option value="Kenya" <%= (typeof selectedCountry !== 'undefined' && selectedCountry === 'KE') ? 'selected' : '' %>>🇰🇪 Kenya</option>
                            <option value="Botswana" <%= (typeof selectedCountry !== 'undefined' && selectedCountry === 'BW') ? 'selected' : '' %>>🇧🇼 Botswana</option>
                            <option value="Malawi" <%= (typeof selectedCountry !== 'undefined' && selectedCountry === 'MW') ? 'selected' : '' %>>🇲🇼 Malawi</option>
                            <option value="Zambia" <%= (typeof selectedCountry !== 'undefined' && selectedCountry === 'ZM') ? 'selected' : '' %>>🇿🇲 Zambia</option>
                            <option value="Nigeria" <%= (typeof selectedCountry !== 'undefined' && selectedCountry === 'NG') ? 'selected' : '' %>>🇳🇬 Nigeria</option>
                            <option value="Tanzania" <%= (typeof selectedCountry !== 'undefined' && selectedCountry === 'TZ') ? 'selected' : '' %>>🇹🇿 Tanzania</option>
                            <option value="Other">Other</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label for="password">Password *</label>
                        <input type="password" id="password" name="password" required
                               placeholder="Minimum 6 characters">
                        <small>Password must be at least 6 characters</small>
                    </div>

                    <div class="form-group">
                        <label for="confirm_password">Confirm Password *</label>
                        <input type="password" id="confirm_password" name="confirm_password" required
                               placeholder="Re-enter password">
                    </div>

                    <div class="form-group">
                        <label for="referral">Referral Code (Optional)</label>
                        <input type="text" id="referral" name="referral"
                               value="<%= referral %>"
                               placeholder="Enter referral code if you have one">
                    </div>

                    <button type="submit" class="submit-btn">Create Account</button>
                </form>

                <div class="login-link">
                    Already have an account? <a href="/login">Login here</a>
                </div>
            </div>
        </div>
    </main>

<%- include('footer') %>

<style>
    .register-container {
        max-width: 500px;
        margin: 60px auto;
        padding: 40px;
        background: #fff;
        border-radius: 12px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.1);
    }

    .register-header {
        text-align: center;
        margin-bottom: 30px;
    }

    .register-header h1 {
        color: #2563eb;
        margin-bottom: 10px;
    }

    .register-header p {
        color: #666;
        font-size: 0.95rem;
    }

    .form-group {
        margin-bottom: 20px;
    }

    .form-group label {
        display: block;
        margin-bottom: 8px;
        font-weight: 500;
        color: #333;
    }

    .form-group input,
    .form-group select {
        width: 100%;
        padding: 12px;
        border: 1px solid #ddd;
        border-radius: 6px;
        font-size: 1rem;
        transition: border-color 0.3s ease;
    }

    .form-group input:focus,
    .form-group select:focus {
        outline: none;
        border-color: #2563eb;
        box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
    }

    .form-group small {
        display: block;
        margin-top: 5px;
        color: #666;
        font-size: 0.85rem;
    }

    .submit-btn {
        width: 100%;
        padding: 14px;
        background: #2563eb;
        color: #fff;
        border: none;
        border-radius: 6px;
        font-size: 1.1rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .submit-btn:hover {
        background: #1e40af;
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(37, 99, 235, 0.3);
    }

    .alert {
        padding: 12px 16px;
        border-radius: 6px;
        margin-bottom: 20px;
    }

    .alert-success {
        background: #d1fae5;
        color: #065f46;
        border: 1px solid #6ee7b7;
    }

    .alert-error {
        background: #fee2e2;
        color: #991b1b;
        border: 1px solid #fca5a5;
    }

    .login-link {
        text-align: center;
        margin-top: 20px;
        color: #666;
    }

    .login-link a {
        color: #2563eb;
        font-weight: 600;
    }

    .features-list {
        background: #f9fafb;
        padding: 20px;
        border-radius: 8px;
        margin-bottom: 30px;
    }

    .features-list h3 {
        color: #1f2937;
        margin-bottom: 15px;
        font-size: 1.1rem;
    }

    .features-list ul {
        list-style: none;
        padding: 0;
    }

    .features-list li {
        padding: 8px 0;
        color: #4b5563;
        padding-left: 24px;
        position: relative;
    }

    .features-list li:before {
        content: '✓';
        position: absolute;
        left: 0;
        color: #10b981;
        font-weight: bold;
    }
</style>
